{
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/images/(.*)",
      "dest": "/images/$1"
    },
    {
      "src": "/styles.css",
      "dest": "/styles.css"
    },
    {
      "src": "/(.+\\.js)$",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.html)$",
      "dest": "/$1"
    },
    {
      "src": "^/$",
      "dest": "/mainpage.html"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
